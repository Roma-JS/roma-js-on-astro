---
import BrandLogo from '@components/BrandLogo/BrandLogo.astro';

export interface Props {
  tagline: string;
}

const { tagline } = Astro.props;
---

<footer class="border-t border-ink bg-paper-soft">
  <div
    class="mx-auto flex w-full max-w-6xl flex-col items-start justify-between gap-3 px-4 py-8 font-mono text-xs text-ink-soft sm:flex-row sm:items-center lg:px-8"
  >
    <div class="flex items-center gap-3">
      <BrandLogo class="h-7 w-7" />
      <span class="font-bold uppercase tracking-widest text-ink">RomaJS</span>
    </div>
    <p class="m-0">© 2014–2026 · {tagline}</p>
  </div>
</footer>
