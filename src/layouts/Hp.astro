---
import '../styles/global.css';
import BaseHead from '@components/BaseHead.astro';
import BrandLogo from '@components/BrandLogo/BrandLogo.astro';
import SiteFooter from '@components/SiteFooter/SiteFooter.astro';
import { BuildInfo } from '@components/BuildInfo/BuildInfo';
import type { Props as BaseHeadProps } from '@components/BaseHead.astro';
import { Navbar } from '@components/Navbar/Navbar';
import type { Lang } from '@i18n/types';
import { getCanonicalURL, socialLinks } from 'utils/routing';
import { getNavbarMessages } from '@components/Navbar/helpers';
import { CFPCta } from '@components/CFPCta/CFPCta';
import type { HpContent } from '../@types/hp';
import { ClientRouter } from 'astro:transitions';
import { h1HeadingDomId } from 'utils/a11y';
import { SkipToMainContent } from '@components/SkipToMainContent/SkipToMainContent';
import eventsMetadata from '../data/events/events-metadata.json';
import { createSlug } from 'utils/slug';
import { createTranslate } from '@i18n/translate';

export interface Props extends BaseHeadProps {
  lang: Lang;
  urlMap?: Partial<Record<Lang, string>>;
  sections: HpContent['sections'];
}

const {
  title,
  description,
  lang = 'en',
  urlMap,
  sections,
} = Astro.props as Props;

const canonicalURL = getCanonicalURL(Astro);
const hrefByEventSlug: Record<string, string | undefined> =
  eventsMetadata.hrefByEventSlug;
const relativePageUrl =
  canonicalURL.pathname.replace(/([^/]+)\/$/g, '$1') +
  canonicalURL.search +
  canonicalURL.hash;

const l10n = await createTranslate(lang);
---

<html lang={lang}>
  <head>
    <BaseHead lang={lang} title={title} description={description} />
    <slot name="head" />
    <ClientRouter />
  </head>

  <body class="bg-paper text-ink">
    <SkipToMainContent
      client:load
      targetId={h1HeadingDomId}
      label={l10n('skipToMainContent')}
    />
    <Navbar
      client:load
      lang={lang}
      urlMap={urlMap}
      relativePageUrl={relativePageUrl}
      messages={getNavbarMessages(l10n)}
    />

    <main class="mx-auto w-full max-w-6xl">
      {/* HERO */}
      <section class="border-b border-ink px-4 pb-20 pt-16 lg:px-8 lg:pb-28 lg:pt-24">
        <div class="mx-auto flex max-w-3xl flex-col items-center text-center">
          <BrandLogo class="mb-6 h-20 w-20 lg:h-24 lg:w-24" />
          <p class="m-0 mb-6 font-mono text-xs uppercase tracking-widest text-ink-soft">
            <span aria-hidden="true">/*</span>&nbsp; ROMA · JS · MEETUP · EST. 2014 &nbsp;<span aria-hidden="true">*/</span>
          </p>
          <h1
            id={h1HeadingDomId}
            tabindex="-1"
            class="m-0 max-w-3xl font-mono text-4xl font-bold leading-[1.05] tracking-tight sm:text-5xl lg:text-6xl"
          >
            {title}<span class="blink ml-1 text-ink-soft" aria-hidden="true">_</span>
          </h1>
          <p class="mt-6 max-w-xl text-sm text-ink-soft lg:text-base">
            {description}
          </p>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-x-5 gap-y-3">
            <a
              class="btn btn--primary"
              rel="noopener noreferrer"
              target="_blank"
              href={socialLinks.discord.href}
            >
              {l10n('ctaJoinDiscordCta')}
            </a>
          </div>
        </div>
      </section>

      {/* EVENTS GRID */}
      <section class="border-b border-ink px-4 py-16 lg:px-8 lg:py-24">
        <header class="mb-8 flex flex-col items-start gap-1 lg:mb-10">
          <p class="m-0 font-mono text-xs uppercase tracking-widest text-ink-soft">
            // schedule
          </p>
          <h2 class="m-0 font-mono text-2xl font-bold tracking-tight lg:text-3xl">
            Upcoming &amp; latest
          </h2>
        </header>
        <div class="grid gap-x-6 gap-y-10 sm:grid-cols-2">
          {
            sections.map((section, idx) => {
              const label = idx === 0 ? 'NEXT' : 'PREV';
              return (
                <article class="ascii-box flex flex-col gap-4">
                  <span class="ascii-box__title">{label}</span>
                  {section.startDate && (
                    <span class="ascii-box__meta">
                      <time datetime={section.startDate.dateTime}>
                        {section.startDate.label}
                      </time>
                    </span>
                  )}
                  <h3 class="m-0 mt-1 font-mono text-xl font-bold leading-tight tracking-tight lg:text-2xl">
                    {section.heading}
                  </h3>
                  <dl class="ascii-dl text-sm lg:text-[15px]">
                    {section.body.map((body, i) => {
                      const slug = createSlug(body);
                      const href: string | undefined = hrefByEventSlug[slug];
                      const key =
                        i === 0 ? 'subject' : `note.${String(i).padStart(2, '0')}`;
                      return (
                        <>
                          <dt>{key}</dt>
                          <dd>{href ? <a href={href}>{body}</a> : body}</dd>
                        </>
                      );
                    })}
                    {section.venues?.length ? (
                      <>
                        <dt>venue</dt>
                        <dd>
                          <a
                            href={section.venues[0].href}
                            hreflang={section.venues[0].lang || undefined}
                          >
                            {section.venues[0].text}
                          </a>
                        </dd>
                      </>
                    ) : null}
                  </dl>
                  <div class="mt-auto flex flex-wrap items-center gap-x-4 gap-y-2 pt-2">
                    {!!section.cta && (
                      <a
                        class="btn btn--primary"
                        href={section.cta.href}
                        hreflang={section.cta.lang || undefined}
                      >
                        {section.cta.text}
                      </a>
                    )}
                  </div>
                </article>
              );
            })
          }
        </div>
      </section>

      <slot />

      {/* CFP */}
      <section class="border-b border-ink px-4 py-16 lg:px-8 lg:py-24">
        <div class="ascii-box mx-auto flex max-w-3xl flex-col items-center gap-5 bg-paper-soft px-6 py-12 text-center lg:px-10 lg:py-16">
          <span class="ascii-box__title">CFP</span>
          <p class="m-0 font-mono text-xs uppercase tracking-widest text-ink-soft">
            // call for proposals
          </p>
          <h2 class="m-0 max-w-xl font-mono text-2xl font-bold leading-tight tracking-tight lg:text-4xl">
            {l10n('ctaRequestTalk')}
          </h2>
          <p class="m-0 max-w-md text-sm text-ink-soft">
            We curate talks every month. If you have a story to tell, the stage is yours.
          </p>
          <CFPCta class="btn--primary">{l10n('ctaSubmitTalk')}</CFPCta>
        </div>
      </section>

      {/* CONTACTS */}
      <section class="px-4 py-16 lg:px-8 lg:py-24">
        <div class="grid items-start gap-10 lg:grid-cols-[1fr_auto]">
          <div class="flex flex-col items-start gap-2">
            <p class="m-0 font-mono text-xs uppercase tracking-widest text-ink-soft">
              // contacts
            </p>
            <h2 class="m-0 font-mono text-2xl font-bold tracking-tight lg:text-3xl">
              {l10n('ctaContacts')}
            </h2>
            <p class="m-0 max-w-prose text-sm text-ink-soft lg:text-base">
              {l10n('ctaDiscussWebDev')} · {l10n('ctaSeePreviousTalks')}
            </p>
          </div>
          <dl class="ascii-dl text-sm lg:text-[15px]">
            {
              Object.entries(socialLinks).map(([name, link]) => (
                <>
                  <dt>{name}</dt>
                  <dd>
                    <a href={link.href} rel="noopener noreferrer" target="_blank">
                      {link.href.replace(/^https?:\/\//, '')}
                    </a>
                  </dd>
                </>
              ))
            }
          </dl>
        </div>
      </section>
    </main>

    <SiteFooter tagline={l10n('footerTagline')} />
    <slot name="after" />
    <BuildInfo />
  </body>
</html>
